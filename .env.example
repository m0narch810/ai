# Copy this file to .env and fill in real values. .env is gitignored.

# --- Altaris auth ---
# Preferred: store your Altaris login and the pipeline auto-fetches + refreshes the
# session cookie itself (logs in via POST /api/login, retries on 401). No manual paste,
# and it works in the cloud too. Username OR email both work for ALTARIS_USER.
ALTARIS_USER=
ALTARIS_PASS=
#
# Optional fallback / override: a pasted session cookie. If ALTARIS_USER/PASS are set
# you can leave this blank. Paste the full `altaris_session=...` from the "Copy as cURL"
# of the /api/data request (DevTools -> Network). Bare token or full string both work.
ALTARIS_COOKIE=

# Base URL of the Altaris terminal API.
ALTARIS_BASE_URL=https://altaris.up.railway.app/api

# Active ticker / symbol.
ALTARIS_SYMBOL=QQQ

# --- Scoring schedule (Eastern Time) ---
SESSION_TZ=America/New_York
# US session: QQQ direct.
SESSION_START=08:30
SESSION_END=17:00
# Asia overnight: QQQ is stale, so price comes from NQ futures converted to QQQ-equiv.
# Window wraps midnight (Sun-Thu evenings through Mon-Fri early hours).
ASIA_START=20:00
ASIA_END=04:00
SCORE_INTERVAL_MIN=15
# AI re-scoring runs RTH only (09:15–16:00 ET). Outside this the loop holds the last RTH
# board's levels but still refreshes spot + reversal outcomes (no AI / no Max usage).
AI_SCORE_START=09:15
AI_SCORE_END=16:00

# --- Scoring (runs through Claude Code on your Max plan — no API key) ---
# Model alias for the CLI: opus | sonnet | haiku, or a full model id.
# Sonnet is plenty for structured greek-scoring and far lighter on Max usage;
# bump to opus only if calibration shows it's better-calibrated.
ANTHROPIC_MODEL=sonnet
# Optional override if `claude` isn't on PATH:
# CLAUDE_BIN=C:\Users\asare\.local\bin\claude.exe

# --- Reversal detection: Yahoo OHLC bars (real intrabar wicks) ---
# Bar interval (1m gives the cleanest wick detection). RTH-only matches the chart.
MARKET_INTERVAL=1m
MARKET_RTH_ONLY=true

# --- Detector / scoring tuning (fractions of spot) ---
# Min take-profit (the 0.25% rule) — used in the AI prompt for level spacing/TP.
TP_MIN_PCT=0.0025
# Swing size that confirms a level actually reversed (a "hold", not a minor poke).
# Higher than TP_MIN so chop near a level isn't mislabeled a reversal. Tune over time.
REVERSAL_SWING_PCT=0.005
# How close a swing pivot must land on a level to count as a reversal there.
TOUCH_TOLERANCE_PCT=0.0010
# How far past a level price must trade to count as a break, not a hold.
BREAK_BUFFER_PCT=0.0015
# Only score/track strikes within this band of spot (actionable window).
NEAR_SPOT_BAND_PCT=0.025

# --- Dashboard publishing (hybrid model) ---
# Scoring stays local on Max; each board writes web/dashboard.json. Serve it on
# your LAN with `npm run web` and open the printed URL on your phone.
# Port for the LAN dashboard server.
WEB_PORT=8787
# Set to "netlify" to also deploy web/ after each score (computer-off viewing).
# Requires: npm i -g netlify-cli && netlify login && netlify link (once).
# PUBLISH_TARGET=netlify
# Optional explicit site id for the deploy (otherwise uses the linked site):
# NETLIFY_SITE_ID=
# NETLIFY_BIN=netlify.cmd
